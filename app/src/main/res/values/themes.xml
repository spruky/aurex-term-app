<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark-only theme. Mirrors aurex_website/term.css: near-black canvas, red accent. -->
    <style name="Theme.AurexTerm" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/red</item>
        <item name="colorPrimaryDark">@color/bg</item>
        <item name="colorAccent">@color/red</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:textColorPrimary">@color/text</item>
        <item name="android:textColorSecondary">@color/text2</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
